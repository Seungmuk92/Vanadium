{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=vanadium;Username=postgres;Password=postgres"
  },
  "Auth": {
    "JwtSecret": "",
    "JwtExpirationMinutes": 480,
    "PasswordHash": "",
    "PasswordPolicy": {
      "MinLength": 15,
      "ContextTerms": [ "vanadium", "note", "owner", "admin", "root", "password", "passwd", "login", "secret", "qwerty" ],
      "EnableBreachCheck": true
    }
  },
  "RecycleBin": {
    "RetentionDays": 30
  },
  "FileCleanup": {
    "GraceMinutes": 60
  },
  "Seq": {
    "ServerUrl": "",
    "ApiKey": ""
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "AllowedHosts": "*"
}
