@using Microsoft.AspNetCore.Components.Authorization
@implements IDisposable
@inject AuthenticationStateProvider AuthStateProvider
@inject Vanadium.Note.Web.Auth.AuthService AuthService
@inject NavigationManager Navigation

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">Vanadium Note</a>
        <button title="Navigation menu" class="navbar-toggler ms-auto" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="nav-wrapper">
    <div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
        <nav class="nav flex-column">
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                    <span class="bi bi-journal-text-nav-menu" aria-hidden="true"></span> Notes
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="board">
                    <span class="bi bi-kanban-nav-menu" aria-hidden="true"></span> Board
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="archive">
                    <span class="bi bi-archive-nav-menu" aria-hidden="true"></span> Archive
                </NavLink>
            </div>
            <div class="nav-item px-3">
                <NavLink class="nav-link" href="recycle-bin">
                    <span class="bi bi-recycle-bin-nav-menu" aria-hidden="true"></span> Recycle Bin
                </NavLink>
            </div>
        </nav>
    </div>

    <div class="user-footer">
        <span class="app-version">v@(AppVersion)</span>
        <MudTooltip Text="@(IsDarkMode ? "Light mode" : "Dark mode")" Placement="Placement.Right">
            <MudIconButton Icon="@(IsDarkMode ? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                           Color="Color.Inherit"
                           Size="Size.Small"
                           OnClick="@(() => ToggleDarkMode.InvokeAsync())" />
        </MudTooltip>
        @if (_username is not null)
        {
            <MudTooltip Text="Settings" Placement="Placement.Right">
                <MudIconButton Icon="@Icons.Material.Filled.Settings"
                               Color="Color.Inherit"
                               Size="Size.Small"
                               OnClick="@(() => Navigation.NavigateTo("/settings"))" />
            </MudTooltip>
            <MudTooltip Text="Logout" Placement="Placement.Right">
                <MudIconButton Icon="@Icons.Material.Filled.Logout"
                               Color="Color.Inherit"
                               Size="Size.Small"
                               OnClick="Logout" />
            </MudTooltip>
        }
    </div>
</div>

@code {
    [CascadingParameter(Name = "IsDarkMode")] public bool IsDarkMode { get; set; }
    [CascadingParameter(Name = "ToggleDarkMode")] public EventCallback ToggleDarkMode { get; set; }

    private static readonly string AppVersion =
        typeof(NavMenu).Assembly.GetName().Version?.ToString(3) ?? "dev";

    private bool collapseNavMenu = true;
    private string? _username;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    protected override async Task OnInitializedAsync()
    {
        AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;
        await UpdateUsernameAsync();
    }

    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        var state = await task;
        _username = GetUsername(state);
        await InvokeAsync(StateHasChanged);
    }

    private async Task UpdateUsernameAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        _username = GetUsername(state);
    }

    private static string? GetUsername(AuthenticationState state)
    {
        var user = state.User;
        if (user.Identity?.IsAuthenticated != true) return null;
        return user.FindFirst("unique_name")?.Value ?? user.Identity.Name;
    }

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private async Task Logout()
    {
        await AuthService.LogoutAsync();
        Navigation.NavigateTo("/login");
    }

    public void Dispose()
    {
        AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
    }
}
