@inherits LayoutComponentBase
@inject IJSRuntime JS
@inject SettingsService SettingsService
@inject ThemeService ThemeService
@inject AuthenticationStateProvider AuthStateProvider
@inject KeyboardShortcutService ShortcutService
@inject TokenStore TokenStore
@inject NavigationManager Nav
@inject ILogger<MainLayout> Logger
@inject ISnackbar Snackbar
@inject NetworkStatusService NetworkStatus
@inject OfflineSaveQueue OfflineQueue
@implements IAsyncDisposable

<MudThemeProvider IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />

<CascadingValue Value="_isDarkMode" Name="IsDarkMode">
    <CascadingValue Value="EventCallback.Factory.Create(this, ToggleDarkMode)" Name="ToggleDarkMode">
        <OfflineBanner />

        <div class="page">
            <div class="sidebar">
                <NavMenu />
            </div>

            <main>
                <article class="content px-4">
                    @Body
                </article>
            </main>
        </div>
    </CascadingValue>
</CascadingValue>

<QuickNavDialog @bind-Open="_quickNavOpen" />

@if (_showShortcutsHelp)
{
    <div class="shortcuts-overlay" @onclick="CloseShortcutsHelp">
        <div class="shortcuts-dialog" @onclick:stopPropagation="true">
            <div class="shortcuts-dialog-header">
                <span>Keyboard Shortcuts</span>
                <button class="shortcuts-close" @onclick="CloseShortcutsHelp">×</button>
            </div>
            <table class="shortcuts-table">
                <tbody>
                    @foreach (var entry in ShortcutService.RegisteredShortcuts)
                    {
                        <tr>
                            <td><kbd>@FormatKey(entry.Key)</kbd></td>
                            <td>@entry.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
}

@code {
    private bool _isDarkMode = false;
    private bool _showShortcutsHelp = false;
    private bool _quickNavOpen = false;

    protected override void OnInitialized()
    {
        ThemeService.OnChanged += OnThemeServiceChanged;
        AuthStateProvider.AuthenticationStateChanged += OnAuthStateChanged;
        Nav.LocationChanged += OnLocationChanged;
        NetworkStatus.OnChanged += OnNetworkChanged;
    }

    // Connectivity flipped. Going offline only needs a re-render (the banner reads the
    // service directly); coming back online is what drains the offline save queue (#211).
    private void OnNetworkChanged()
    {
        InvokeAsync(async () =>
        {
            StateHasChanged();
            if (NetworkStatus.IsOnline)
                await FlushOfflineQueueAsync();
        });
    }

    private async Task FlushOfflineQueueAsync()
    {
        try
        {
            // Replaying without a token would 401, and AuthTokenHandler turns that into a
            // redirect to /login — a jarring bounce for someone sitting on the login page.
            // The queue is durable, so it simply waits until the next reconnect after login.
            var state = await AuthStateProvider.GetAuthenticationStateAsync();
            if (state.User.Identity?.IsAuthenticated != true)
                return;

            var flushed = await OfflineQueue.FlushAsync();
            if (flushed > 0)
                Snackbar.Add(
                    $"Back online — synced {flushed} offline change{(flushed == 1 ? string.Empty : "s")}.",
                    Severity.Success);
        }
        catch (Exception ex)
        {
            // Never let a flush failure tear down the layout; the entries that did not
            // land stay queued and are retried on the next reconnect.
            Logger.LogError(ex, "Failed to flush queued offline saves.");
        }
    }

    // Never leave the palette overlay stuck across a route change (E10).
    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs e)
    {
        if (_quickNavOpen)
        {
            _quickNavOpen = false;
            InvokeAsync(StateHasChanged);
        }
    }

    private void ToggleQuickNav()
    {
        _quickNavOpen = !_quickNavOpen;
        StateHasChanged();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            await LoadThemeAsync();
            await TokenStore.InitAsync();
            await ShortcutService.InitAsync();
            await ShortcutService.RegisterAsync("ctrl+n", "New note", () => InvokeAsync(() =>
            {
                Nav.NavigateTo("/editor");
                return Task.CompletedTask;
            }));
            await ShortcutService.RegisterAsync("ctrl+/", "Show keyboard shortcuts", () => InvokeAsync(() =>
            {
                _showShortcutsHelp = !_showShortcutsHelp;
                StateHasChanged();
                return Task.CompletedTask;
            }));
            await ShortcutService.RegisterAsync("ctrl+k", "Quick navigation", () => InvokeAsync(ToggleQuickNav));
            await NetworkStatus.InitAsync();
            // A save parked in a previous session (tab closed while offline) is still
            // queued — drain it as soon as the app comes up online (#211).
            if (NetworkStatus.IsOnline)
                await FlushOfflineQueueAsync();
        }
    }

    private void CloseShortcutsHelp() => _showShortcutsHelp = false;

    private static string FormatKey(string key)
    {
        return string.Join("+", key.Split('+').Select(part => part switch
        {
            "ctrl"  => "Ctrl",
            "alt"   => "Alt",
            "shift" => "Shift",
            "meta"  => "Meta",
            var k   => char.ToUpperInvariant(k[0]) + k[1..],
        }));
    }

    private void OnThemeServiceChanged()
    {
        _isDarkMode = ThemeService.IsDarkMode;
        InvokeAsync(StateHasChanged);
    }

    // async void handler: exceptions cannot be observed by a caller, so they
    // must be caught here — an unhandled throw would tear down the renderer.
    private async void OnAuthStateChanged(Task<AuthenticationState> task)
    {
        try
        {
            var state = await task;
            if (state.User.Identity?.IsAuthenticated == true)
                await LoadThemeAsync();
            else
                await ApplyThemeAsync("system");
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Failed to handle authentication state change.");
        }
    }

    private async Task LoadThemeAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated != true)
        {
            await ApplyThemeAsync("system");
            return;
        }

        var result = await SettingsService.GetAsync();
        if (result.IsSuccess)
            await ApplyThemeAsync(result.Value!.Theme);
    }

    private async Task ApplyThemeAsync(string theme)
    {
        await JS.InvokeVoidAsync("storeTheme", theme);
        await JS.InvokeVoidAsync("applyTheme", theme);
        var isDark = theme == "dark" || (theme == "system" && await JS.InvokeAsync<bool>("getSystemDarkMode"));
        ThemeService.SetDarkMode(isDark);
    }

    private async Task ToggleDarkMode()
    {
        var isDark = !_isDarkMode;
        var theme = isDark ? "dark" : "light";
        await JS.InvokeVoidAsync("setDarkMode", isDark);
        await JS.InvokeVoidAsync("storeTheme", theme);
        ThemeService.SetDarkMode(isDark);

        // When logged in, persist the toggle to the saved settings so it
        // survives a reload (LoadThemeAsync re-reads the server value).
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
        {
            var result = await SettingsService.GetAsync();
            if (result.IsSuccess)
            {
                var settings = result.Value!;
                if (settings.Theme != theme)
                {
                    settings.Theme = theme;
                    await SettingsService.SaveAsync(settings);
                }
            }
        }
    }

    public async ValueTask DisposeAsync()
    {
        ThemeService.OnChanged -= OnThemeServiceChanged;
        AuthStateProvider.AuthenticationStateChanged -= OnAuthStateChanged;
        Nav.LocationChanged -= OnLocationChanged;
        NetworkStatus.OnChanged -= OnNetworkChanged;
        await ShortcutService.UnregisterManyAsync("ctrl+n", "ctrl+/", "ctrl+k");
    }
}
