@page "/"
@attribute [Authorize]
@inject NoteService NoteService
@inject LabelService LabelService
@inject NavigationManager Nav
@inject IJSRuntime JS
@implements IAsyncDisposable

<PageTitle>Notes</PageTitle>

<div class="notes-header">
    <h1>Notes</h1>
    <input class="notes-search"
           type="search"
           placeholder="Search by title..."
           value="@searchText"
           @oninput="e => searchText = e.Value?.ToString() ?? string.Empty" />
    <button class="btn btn-primary" @onclick="CreateNote">New Note</button>
</div>

@if (allLabels.Any())
{
    <div class="label-filter-bar">
        <span class="label-filter-title">Filter:</span>
        @foreach (var label in allLabels)
        {
            var active = activeFilters.Contains(label.Id);
            <span class="filter-chip @(active ? "filter-chip-active" : "") @(label.CategoryId.HasValue ? "filter-chip-cat" : "")"
                  @onclick="() => ToggleFilter(label.Id)">
                @if (label.CategoryId.HasValue)
                {
                    <span class="filter-chip-cat-prefix">@label.CategoryName:</span>
                }
                @label.Name
            </span>
        }
        @if (activeFilters.Any())
        {
            <button class="filter-clear-btn" @onclick="ClearFilters">× Clear</button>
        }
    </div>
}

@if (!notes.Any())
{
    <p class="empty-message">No notes yet. Create one!</p>
}
else if (!FilteredNotes.Any())
{
    <p class="empty-message">No notes match the selected labels.</p>
}
else
{
    <div class="note-table">
        <div class="note-row note-header">
            <div class="col-check">
                <input type="checkbox"
                       class="note-checkbox"
                       checked="@IsAllSelected"
                       @onchange="ToggleSelectAll" />
            </div>
            <div class="col-title sortable" @onclick="() => SetSort(SortColumn.Title)">
                Title @SortIcon(SortColumn.Title)
            </div>
            <div class="col-date sortable" @onclick="() => SetSort(SortColumn.Date)">
                Modified @SortIcon(SortColumn.Date)
            </div>
        </div>
        @foreach (var note in FilteredNotes)
        {
            <div class="note-row note-item @(selectedIds.Contains(note.Id) ? "selected" : "")">
                <div class="col-check">
                    <input type="checkbox"
                           class="note-checkbox"
                           checked="@selectedIds.Contains(note.Id)"
                           @onchange="() => ToggleSelect(note.Id)"
                           @onclick:stopPropagation="true" />
                </div>
                <div class="col-title" @onclick="() => EditNote(note.Id)">
                    <div class="note-title-text">
                        @(string.IsNullOrWhiteSpace(note.Title) ? "(No title)" : note.Title)
                    </div>
                    @if (note.Labels?.Any() == true)
                    {
                        <div class="note-label-chips">
                            @foreach (var label in note.Labels)
                            {
                                <span class="note-label-chip @(label.CategoryId.HasValue ? "note-label-chip-cat" : "")"
                                      @onclick:stopPropagation="true"
                                      @onclick="() => ToggleFilter(label.Id)">
                                    @if (label.CategoryId.HasValue)
                                    {
                                        <span class="note-label-cat-prefix">@label.CategoryName:</span>
                                    }
                                    @label.Name
                                </span>
                            }
                        </div>
                    }
                </div>
                <div class="col-date" @onclick="() => EditNote(note.Id)">
                    @note.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                </div>
            </div>
        }
    </div>
}

@code {
    private IReadOnlyList<NoteItem> notes = [];
    private List<Label> allLabels = [];
    private HashSet<Guid> selectedIds = [];
    private HashSet<Guid> activeFilters = [];
    private string searchText = string.Empty;
    private DotNetObjectReference<Home>? dotNetRef;

    private enum SortColumn { Title, Date }
    private SortColumn currentSort = SortColumn.Date;
    private bool sortAscending = false;

    private IEnumerable<NoteItem> SortedNotes => currentSort switch
    {
        SortColumn.Title => sortAscending
            ? notes.OrderBy(n => n.Title)
            : notes.OrderByDescending(n => n.Title),
        SortColumn.Date => sortAscending
            ? notes.OrderBy(n => n.UpdatedAt)
            : notes.OrderByDescending(n => n.UpdatedAt),
        _ => notes
    };

    private IEnumerable<NoteItem> FilteredNotes
    {
        get
        {
            var result = SortedNotes;
            if (!string.IsNullOrWhiteSpace(searchText))
                result = result.Where(n => (n.Title ?? string.Empty).Contains(searchText, StringComparison.OrdinalIgnoreCase));
            if (activeFilters.Count > 0)
                result = result.Where(n => activeFilters.All(f => (n.Labels ?? []).Any(l => l.Id == f)));
            return result;
        }
    }

    private bool IsAllSelected => notes.Count > 0 && selectedIds.Count == notes.Count;

    private string SortIcon(SortColumn col)
    {
        if (currentSort != col) return "⇅";
        return sortAscending ? "↑" : "↓";
    }

    private void SetSort(SortColumn col)
    {
        if (currentSort == col)
            sortAscending = !sortAscending;
        else
        {
            currentSort = col;
            sortAscending = true;
        }
    }

    protected override async Task OnInitializedAsync()
    {
        notes = await NoteService.GetAllAsync() ?? [];
        allLabels = await LabelService.GetLabelsAsync() ?? [];
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("registerDeleteKey", dotNetRef);
        }
    }

    [JSInvokable]
    public async Task OnDeleteKeyPressed()
    {
        if (selectedIds.Count == 0) return;

        var confirmed = await JS.InvokeAsync<bool>("confirm", $"Delete {selectedIds.Count} selected note(s)?");
        if (!confirmed) return;

        foreach (var id in selectedIds)
            await NoteService.DeleteAsync(id);

        selectedIds.Clear();
        notes = await NoteService.GetAllAsync() ?? [];
        StateHasChanged();
    }

    private void ToggleSelect(Guid id)
    {
        if (!selectedIds.Add(id))
            selectedIds.Remove(id);
    }

    private void ToggleSelectAll()
    {
        if (IsAllSelected)
            selectedIds.Clear();
        else
            selectedIds = notes.Select(n => n.Id).ToHashSet();
    }

    private void ToggleFilter(Guid labelId)
    {
        if (activeFilters.Contains(labelId))
        {
            activeFilters.Remove(labelId);
            return;
        }

        var label = allLabels.FirstOrDefault(l => l.Id == labelId);
        if (label?.CategoryId.HasValue == true)
        {
            var sameCategory = allLabels
                .Where(l => l.CategoryId == label.CategoryId)
                .Select(l => l.Id);
            foreach (var id in sameCategory)
                activeFilters.Remove(id);
        }

        activeFilters.Add(labelId);
    }

    private void ClearFilters() => activeFilters.Clear();

    private void CreateNote()
    {
        Nav.NavigateTo("/editor");
    }

    private void EditNote(Guid id)
    {
        Nav.NavigateTo($"/editor/{id}");
    }

    public async ValueTask DisposeAsync()
    {
        await JS.InvokeVoidAsync("unregisterDeleteKey");
        dotNetRef?.Dispose();
    }
}
