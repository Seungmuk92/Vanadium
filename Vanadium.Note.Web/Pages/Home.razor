@page "/"
@attribute [Authorize]
@inject NoteService NoteService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ILogger<Home> Logger
@inject ISnackbar Snackbar
@inject KeyboardShortcutService ShortcutService
@implements IAsyncDisposable

<PageTitle>Notes</PageTitle>

<div class="home-page">
    <div class="notes-header">
        <h1>Notes</h1>
        <input class="notes-search"
               type="search"
               placeholder="Search by title..."
               value="@_searchText"
               @oninput="OnSearchInput" />
        <button class="btn btn-primary" @onclick="CreateNote">New Note</button>
    </div>

    @if (allLabels.Any())
    {
        <div class="label-filter-bar">
            <span class="label-filter-title">Filter:</span>
            @foreach (var label in allLabels)
            {
                var active = activeFilters.Contains(label.Id);
                <span class="filter-chip @(active ? "filter-chip-active" : "") @(label.CategoryId.HasValue ? "filter-chip-cat" : "")"
                      @onclick="() => ToggleFilter(label.Id)">
                    @if (label.CategoryId.HasValue)
                    {
                        <span class="filter-chip-cat-prefix">@label.CategoryName:</span>
                    }
                    @label.Name
                </span>
            }
            @if (activeFilters.Any())
            {
                <button class="filter-clear-btn" @onclick="ClearFilters">× Clear</button>
            }
        </div>
    }

    @if (isLoading && !notes.Any())
    {
        <p class="empty-message">Loading...</p>
    }
    else if (!isLoading && !notes.Any())
    {
        <p class="empty-message">
            @(totalCount == 0 && string.IsNullOrWhiteSpace(_searchText) && !activeFilters.Any()
                ? "No notes yet. Create one!"
                : "No notes match the current filter.")
        </p>
    }
    else
    {
        <div class="note-table">
            <div class="note-row note-header">
                <div class="col-check">
                    <input type="checkbox"
                           class="note-checkbox"
                           checked="@IsAllSelected"
                           @onchange="ToggleSelectAll" />
                </div>
                <div class="col-title sortable" @onclick="() => SetSort(SortColumn.Title)">
                    Title @SortIcon(SortColumn.Title)
                </div>
                <div class="col-date sortable" @onclick="() => SetSort(SortColumn.Date)">
                    Modified @SortIcon(SortColumn.Date)
                </div>
            </div>
            @foreach (var note in notes)
            {
                <div class="note-row note-item @(selectedIds.Contains(note.Id) ? "selected" : "")">
                    <div class="col-check">
                        <input type="checkbox"
                               class="note-checkbox"
                               checked="@selectedIds.Contains(note.Id)"
                               @onchange="() => ToggleSelect(note.Id)"
                               @onclick:stopPropagation="true" />
                    </div>
                    <div class="col-title" @onclick="() => EditNote(note.Id)">
                        @if (!string.IsNullOrWhiteSpace(_searchText) && !string.IsNullOrWhiteSpace(note.ParentTitle))
                        {
                            <div class="note-parent-crumb">
                                <span class="parent-crumb-icon">📁</span>
                                <span class="parent-crumb-text">@note.ParentTitle</span>
                                <span class="parent-crumb-sep">›</span>
                            </div>
                        }
                        <div class="note-title-row">
                            @if (note.ChildCount > 0)
                            {
                                <button class="expand-btn @(expandedNoteIds.Contains(note.Id) ? "expanded" : "")"
                                        @onclick:stopPropagation="true"
                                        @onclick="() => ToggleExpand(note.Id)">
                                    ▶
                                </button>
                            }
                            else
                            {
                                <span class="expand-btn-placeholder"></span>
                            }
                            <div class="note-title-text">
                                @(string.IsNullOrWhiteSpace(note.Title) ? "(No title)" : note.Title)
                            </div>
                        </div>
                        @if (note.Labels?.Any() == true)
                        {
                            <div class="note-label-chips">
                                @foreach (var label in note.Labels)
                                {
                                    <span class="note-label-chip @(label.CategoryId.HasValue ? "note-label-chip-cat" : "")"
                                          @onclick:stopPropagation="true"
                                          @onclick="() => ToggleFilter(label.Id)">
                                        @if (label.CategoryId.HasValue)
                                        {
                                            <span class="note-label-cat-prefix">@label.CategoryName:</span>
                                        }
                                        @label.Name
                                    </span>
                                }
                            </div>
                        }
                    </div>
                    <div class="col-date" @onclick="() => EditNote(note.Id)">
                        @note.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                    </div>
                </div>

                @if (expandedNoteIds.Contains(note.Id))
                {
                    @if (loadingChildrenIds.Contains(note.Id))
                    {
                        <div class="note-row note-child-row">
                            <div class="col-check"></div>
                            <div class="col-title" style="opacity:0.45; font-size:0.82rem; padding-left:1.75rem;">Loading...</div>
                            <div class="col-date"></div>
                        </div>
                    }
                    else if (childrenCache.TryGetValue(note.Id, out var children))
                    {
                        @foreach (var child in children)
                        {
                            <div class="note-row note-item note-child-row @(selectedIds.Contains(child.Id) ? "selected" : "")">
                                <div class="col-check">
                                    <input type="checkbox"
                                           class="note-checkbox"
                                           checked="@selectedIds.Contains(child.Id)"
                                           @onchange="() => ToggleSelect(child.Id)"
                                           @onclick:stopPropagation="true" />
                                </div>
                                <div class="col-title" @onclick="() => EditNote(child.Id)">
                                    <div class="note-title-row note-child-indent">
                                        <span class="child-indicator">└</span>
                                        <div class="note-title-text">
                                            @(string.IsNullOrWhiteSpace(child.Title) ? "(No title)" : child.Title)
                                        </div>
                                        @if (child.ChildCount > 0)
                                        {
                                            <span class="child-count-badge">+@child.ChildCount</span>
                                        }
                                    </div>
                                    @if (child.Labels?.Any() == true)
                                    {
                                        <div class="note-label-chips" style="padding-left:1.75rem;">
                                            @foreach (var label in child.Labels)
                                            {
                                                <span class="note-label-chip @(label.CategoryId.HasValue ? "note-label-chip-cat" : "")"
                                                      @onclick:stopPropagation="true"
                                                      @onclick="() => ToggleFilter(label.Id)">
                                                    @if (label.CategoryId.HasValue)
                                                    {
                                                        <span class="note-label-cat-prefix">@label.CategoryName:</span>
                                                    }
                                                    @label.Name
                                                </span>
                                            }
                                        </div>
                                    }
                                </div>
                                <div class="col-date" @onclick="() => EditNote(child.Id)">
                                    @child.UpdatedAt.ToLocalTime().ToString("yyyy-MM-dd HH:mm")
                                </div>
                            </div>
                        }
                    }
                }
            }
        </div>

        @if (TotalPages > 1)
        {
            <div class="pagination-bar">
                <div class="pagination-controls">
                    <button class="page-btn" disabled="@(currentPage == 1)" @onclick="() => OnPageChanged(1)">«</button>
                    <button class="page-btn" disabled="@(currentPage == 1)" @onclick="() => OnPageChanged(currentPage - 1)">‹</button>
                    @for (int i = Math.Max(1, currentPage - 2); i <= Math.Min(TotalPages, currentPage + 2); i++)
                    {
                        var p = i;
                        <button class="page-btn @(p == currentPage ? "page-btn-active" : "")" @onclick="() => OnPageChanged(p)">@p</button>
                    }
                    <button class="page-btn" disabled="@(currentPage == TotalPages)" @onclick="() => OnPageChanged(currentPage + 1)">›</button>
                    <button class="page-btn" disabled="@(currentPage == TotalPages)" @onclick="() => OnPageChanged(TotalPages)">»</button>
                </div>
                <span class="pagination-info">@totalCount notes</span>
            </div>
        }
    }
</div>

@code {
    private List<NoteSummary> notes = [];
    private List<Label> allLabels = [];
    private HashSet<Guid> selectedIds = [];
    private HashSet<Guid> activeFilters = [];
    private HashSet<Guid> expandedNoteIds = [];
    private HashSet<Guid> loadingChildrenIds = [];
    private Dictionary<Guid, List<NoteSummary>> childrenCache = [];
    private string _searchText = string.Empty;
    private CancellationTokenSource? _searchCts;
    private CancellationTokenSource? _loadCts;

    private int currentPage = 1;
    private int totalCount = 0;
    private const int PageSize = 30;
    private bool isLoading = false;

    private enum SortColumn { Title, Date }
    private SortColumn currentSort = SortColumn.Date;
    private bool sortAscending = false;

    private int TotalPages => Math.Max(1, (int)Math.Ceiling((double)totalCount / PageSize));
    private bool IsAllSelected => notes.Count > 0 && notes.All(n => selectedIds.Contains(n.Id));

    private string SortIcon(SortColumn col)
    {
        if (currentSort != col) return "⇅";
        return sortAscending ? "↑" : "↓";
    }

    protected override async Task OnInitializedAsync()
    {
        _loadCts = new CancellationTokenSource();
        var token = _loadCts.Token;
        isLoading = true;

        var result = await NoteService.GetAllAsync(
            currentPage, PageSize, null,
            currentSort == SortColumn.Title ? "title" : "date",
            sortAscending ? "asc" : "desc",
            null,
            includeLabels: true,
            cancellationToken: token);

        if (result.IsSuccess)
        {
            allLabels = result.Value!.Labels ?? [];
            notes = result.Value!.Items;
            totalCount = result.Value!.TotalCount;
            if (currentPage > TotalPages && TotalPages > 0)
                currentPage = TotalPages;
        }
        else
        {
            Snackbar.Add(result.Error ?? "Failed to load notes.", Severity.Error);
        }

        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
            await ShortcutService.RegisterAsync("delete", "Delete selected notes", () => InvokeAsync(OnDeleteKeyPressed));
    }

    private async Task LoadNotes()
    {
        // Cancel any in-flight request so only the latest call updates the UI
        _loadCts?.Cancel();
        _loadCts?.Dispose();
        _loadCts = new CancellationTokenSource();
        var token = _loadCts.Token;

        isLoading = true;
        StateHasChanged();

        try
        {
            while (true)
            {
                var result = await NoteService.GetAllAsync(
                    currentPage,
                    PageSize,
                    string.IsNullOrWhiteSpace(_searchText) ? null : _searchText,
                    currentSort == SortColumn.Title ? "title" : "date",
                    sortAscending ? "asc" : "desc",
                    activeFilters.Count > 0 ? activeFilters : null,
                    cancellationToken: token);

                if (!result.IsSuccess)
                {
                    Snackbar.Add(result.Error ?? "Failed to load notes.", Severity.Error);
                    break;
                }

                notes = result.Value!.Items;
                totalCount = result.Value!.TotalCount;

                // Page out of range after deletion — clamp and retry with the same token
                if (currentPage > TotalPages && TotalPages > 0)
                    currentPage = TotalPages;
                else
                    break;
            }
        }
        catch (OperationCanceledException)
        {
            // A newer LoadNotes() call took over — do not update UI state
            return;
        }

        expandedNoteIds.Clear();
        childrenCache.Clear();
        isLoading = false;
        StateHasChanged();
    }

    private async Task ToggleExpand(Guid noteId)
    {
        if (!expandedNoteIds.Remove(noteId))
        {
            expandedNoteIds.Add(noteId);
            if (!childrenCache.ContainsKey(noteId))
            {
                loadingChildrenIds.Add(noteId);
                StateHasChanged();

                var result = await NoteService.GetChildrenAsync(noteId);
                loadingChildrenIds.Remove(noteId);

                if (result.IsSuccess)
                    childrenCache[noteId] = result.Value!;
                else
                    Snackbar.Add(result.Error ?? "Failed to load sub-notes.", Severity.Warning);
            }
        }
        StateHasChanged();
    }

    private async Task OnSearchInput(ChangeEventArgs e)
    {
        _searchText = e.Value?.ToString() ?? string.Empty;

        _searchCts?.Cancel();
        _searchCts?.Dispose();
        _searchCts = new CancellationTokenSource();
        var token = _searchCts.Token;

        try
        {
            await Task.Delay(300, token);
            currentPage = 1;
            selectedIds.Clear();
            await LoadNotes();
        }
        catch (TaskCanceledException) { }
    }

    private async Task SetSort(SortColumn col)
    {
        if (currentSort == col)
            sortAscending = !sortAscending;
        else
        {
            currentSort = col;
            sortAscending = true;
        }
        currentPage = 1;
        selectedIds.Clear();
        await LoadNotes();
    }

    private async Task ToggleFilter(Guid labelId)
    {
        if (activeFilters.Contains(labelId))
        {
            activeFilters.Remove(labelId);
        }
        else
        {
            var label = allLabels.FirstOrDefault(l => l.Id == labelId);
            if (label?.CategoryId.HasValue == true)
            {
                var sameCategory = allLabels
                    .Where(l => l.CategoryId == label.CategoryId)
                    .Select(l => l.Id);
                foreach (var id in sameCategory)
                    activeFilters.Remove(id);
            }
            activeFilters.Add(labelId);
        }

        currentPage = 1;
        selectedIds.Clear();
        await LoadNotes();
    }

    private async Task ClearFilters()
    {
        activeFilters.Clear();
        currentPage = 1;
        selectedIds.Clear();
        await LoadNotes();
    }

    private async Task OnPageChanged(int page)
    {
        currentPage = page;
        selectedIds.Clear();
        await LoadNotes();
    }

    private async Task OnDeleteKeyPressed()
    {
        if (selectedIds.Count == 0) return;

        var hasChildren = notes
            .Where(n => selectedIds.Contains(n.Id))
            .Any(n => n.ChildCount > 0);

        var message = hasChildren
            ? $"Delete {selectedIds.Count} note(s)? Some notes have sub-notes that will also be permanently deleted."
            : $"Delete {selectedIds.Count} selected note(s)?";

        var confirmed = await JS.InvokeAsync<bool>("confirm", message);
        if (!confirmed) return;

        Logger.LogInformation("Deleting {Count} note(s).", selectedIds.Count);
        var failCount = 0;
        foreach (var id in selectedIds.ToList())
        {
            var result = await NoteService.DeleteAsync(id);
            if (!result.IsSuccess)
                failCount++;
        }
        if (failCount > 0)
            Snackbar.Add($"Failed to delete {failCount} note(s).", Severity.Error);

        selectedIds.Clear();
        await LoadNotes();
    }

    private void ToggleSelect(Guid id)
    {
        if (!selectedIds.Add(id))
            selectedIds.Remove(id);
    }

    private void ToggleSelectAll()
    {
        if (IsAllSelected)
            selectedIds.Clear();
        else
            foreach (var note in notes)
                selectedIds.Add(note.Id);
    }

    private void CreateNote() => Nav.NavigateTo("/editor");

    private void EditNote(Guid id) => Nav.NavigateTo($"/editor/{id}");

    public async ValueTask DisposeAsync()
    {
        _searchCts?.Cancel();
        _searchCts?.Dispose();
        _loadCts?.Cancel();
        _loadCts?.Dispose();
        await ShortcutService.UnregisterAsync("delete");
    }
}
