@page "/editor"
@page "/editor/{Id:guid}"
@attribute [Authorize]
@using System.IO
@using System.Text.Json.Serialization
@inject NoteService NoteService
@inject LabelService LabelService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject HttpClient Http
@inject TokenStore TokenStore
@inject ILogger<NoteEditor> Logger
@inject ISnackbar Snackbar
@inject IDialogService DialogService
@inject KeyboardShortcutService ShortcutService
@inject QuickNavService QuickNav
@implements IAsyncDisposable

<PageTitle>@(isNew ? "New Note" : "Edit Note")</PageTitle>

<div class="editor-header">
    <button class="btn btn-outline-secondary" @onclick="GoBack">← Back</button>
    @if (parentNoteId.HasValue || parentTitle is not null)
    {
        <div class="editor-breadcrumb">
            <a href="/">Notes</a>
            <span class="breadcrumb-sep">/</span>
            <a href="/editor/@parentNoteId">@(string.IsNullOrWhiteSpace(parentTitle) ? "(Untitled)" : parentTitle)</a>
        </div>
    }
    <span class="save-status @saveStatusCss">@saveStatusText</span>
    <div class="editor-actions">
        @if (!isNew)
        {
            @if (!IsArchived)
            {
                <button class="btn btn-outline-secondary" @onclick="CreateSubNote">+ Sub-note</button>
            }
            <button class="btn btn-outline-secondary" @onclick="ExportMarkdown">Export MD</button>
            @if (!IsArchived)
            {
                <button class="btn btn-outline-secondary" @onclick="ArchiveNote">Archive</button>
            }
            <button class="btn btn-outline-danger" @onclick="DeleteNote">Delete</button>
        }
        @if (!IsArchived)
        {
            <button class="btn btn-primary" @onclick="SaveNote">Save</button>
        }
    </div>
</div>

@if (IsArchived)
{
    <div class="archived-banner">
        <span>🗄 This note is archived and read-only.</span>
        <div class="archived-banner-actions">
            <button class="btn btn-sm btn-outline-secondary" @onclick="UnarchiveNote">Unarchive</button>
        </div>
    </div>
}

@if (_hasConflict)
{
    <div class="conflict-banner">
        <span>⚠ This note was modified in another tab. Your changes were not saved.</span>
        <div class="conflict-banner-actions">
            <button class="btn btn-sm btn-danger" @onclick="ForceSave">Force Save</button>
            <button class="btn btn-sm btn-outline-secondary" @onclick="ReloadNote">Reload Latest</button>
        </div>
    </div>
}

<div class="editor-body">
    <input class="editor-title"
           type="text"
           placeholder="Title"
           value="@title"
           disabled="@IsArchived"
           @oninput="OnTitleInput"
           @onkeydown="OnTitleKeyDown" />

    <div class="label-bar">
        @foreach (var label in noteLabels)
        {
            <span class="label-chip @(label.CategoryId.HasValue ? "label-chip-cat" : "")">
                @if (label.CategoryId.HasValue)
                {
                    <span class="label-cat-prefix">@label.CategoryName:</span>
                }
                <span>@label.Name</span>
                @if (!IsArchived)
                {
                    <button class="label-chip-remove" @onclick="() => RemoveLabel(label.Id)">×</button>
                }
            </span>
        }

        @if (!IsArchived)
        {
        <div class="label-add-wrapper">
            <button class="label-add-btn @(showLabelPicker ? "label-add-btn-active" : "")" @onclick="ToggleLabelPicker">
                + Label
            </button>

            @if (showLabelPicker)
            {
                <div class="label-picker-backdrop" @onclick="CloseLabelPicker"></div>
                <div class="label-picker">
                    @{
                        var generalLabels = availableLabels.Where(l => !l.CategoryId.HasValue).ToList();
                    }

                    @if (generalLabels.Any())
                    {
                        <div class="label-picker-section">
                            <div class="label-picker-section-title">General</div>
                            @foreach (var lbl in generalLabels)
                            {
                                var isAdded = noteLabels.Any(nl => nl.Id == lbl.Id);
                                <div class="label-picker-item @(isAdded ? "is-added" : "")" @onclick="() => ToggleLabel(lbl)">
                                    <span class="label-picker-check">@(isAdded ? "✓" : "")</span>
                                    <span>@lbl.Name</span>
                                </div>
                            }
                        </div>
                    }

                    @foreach (var cat in labelCategories)
                    {
                        var catLabels = availableLabels.Where(l => l.CategoryId == cat.Id).ToList();
                        if (!catLabels.Any()) continue;
                        <div class="label-picker-section">
                            <div class="label-picker-section-title">@cat.Name</div>
                            @foreach (var lbl in catLabels)
                            {
                                var isAdded = noteLabels.Any(nl => nl.Id == lbl.Id);
                                <div class="label-picker-item @(isAdded ? "is-added" : "")" @onclick="() => ToggleLabel(lbl)">
                                    <span class="label-picker-check">@(isAdded ? "✓" : "")</span>
                                    <span>@lbl.Name</span>
                                </div>
                            }
                        </div>
                    }

                    @if (!availableLabels.Any())
                    {
                        <div class="label-picker-empty">No labels</div>
                    }

                    <div class="label-picker-divider"></div>
                    <div class="label-picker-manage-btn" @onclick="ToggleLabelManager">Manage labels...</div>
                </div>
            }
        </div>
        }
    </div>

    @if (showLabelManager)
    {
        <div class="label-manager">
            <div class="label-manager-header">
                <strong>Manage Labels</strong>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleLabelManager">Close</button>
            </div>
            <div class="label-manager-body">
                <div class="label-manager-section">
                    <div class="label-manager-section-title">Categories</div>
                    @foreach (var cat in labelCategories)
                    {
                        <div class="label-manager-item">
                            <span>@cat.Name</span>
                            <button class="label-mgr-delete" @onclick="() => DeleteCategory(cat.Id)">×</button>
                        </div>
                    }
                    <div class="label-manager-new">
                        <input class="label-manager-input @(categoryError is not null ? "input-error" : "")"
                               @bind="newCategoryName"
                               @oninput="() => categoryError = null"
                               placeholder="Category name" />
                        <button class="btn btn-sm btn-primary" @onclick="CreateCategory">Add</button>
                    </div>
                    @if (categoryError is not null)
                    {
                        <div class="label-manager-error">@categoryError</div>
                    }
                </div>

                <div class="label-manager-section">
                    <div class="label-manager-section-title">Labels</div>
                    @foreach (var lbl in availableLabels)
                    {
                        <div class="label-manager-item">
                            <span>
                                @if (lbl.CategoryId.HasValue)
                                {
                                    <span class="label-mgr-cat-prefix">[@lbl.CategoryName]</span>
                                }
                                @lbl.Name
                            </span>
                            <button class="label-mgr-delete" @onclick="() => DeleteLabel(lbl.Id)">×</button>
                        </div>
                    }
                    <div class="label-manager-new">
                        <input class="label-manager-input @(labelError is not null ? "input-error" : "")"
                               @bind="newLabelName"
                               @oninput="() => labelError = null"
                               placeholder="Label name" />
                        <select class="label-manager-select" @bind="newLabelCategoryStr">
                            <option value="">General</option>
                            @foreach (var cat in labelCategories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                        <button class="btn btn-sm btn-primary" @onclick="CreateLabel">Add</button>
                    </div>
                    @if (labelError is not null)
                    {
                        <div class="label-manager-error">@labelError</div>
                    }
                </div>
            </div>
        </div>
    }

    <div id="@_editorId" class="tiptap-wrapper"></div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }
    [SupplyParameterFromQuery(Name = "returnUrl")] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery(Name = "parentId")] public Guid? ParentId { get; set; }

    private string BackUrl
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(ReturnUrl)) return ReturnUrl;
            return "/";
        }
    }

    private string title = string.Empty;
    private string content = string.Empty;
    private bool isNew => Id is null;
    private DateTime? archivedAt;
    private bool IsArchived => archivedAt is not null;
    private Guid? parentNoteId;
    private string? parentTitle;
    private int childCount;

    private Guid? _currentId;
    private Guid? _currentParentId;
    private bool _editorMounted = false;
    private bool _contentJustLoaded = false;
    private readonly string _editorId = "tiptap-" + Guid.NewGuid().ToString("N")[..8];
    private DotNetObjectReference<NoteEditor>? _objRef;
    private CancellationTokenSource? _debounceCts;
    private bool _hasPendingChanges = false;
    private bool _isSaving = false;
    private bool _isDisposing = false;
    private bool _hasConflict = false;
    private DateTime _serverUpdatedAt;
    private string saveStatusText = string.Empty;
    private string saveStatusCss = string.Empty;

    // Label state
    private List<Label> noteLabels = [];
    private List<Label> availableLabels = [];
    private List<LabelCategory> labelCategories = [];
    private bool showLabelPicker = false;
    private bool showLabelManager = false;
    private string newLabelName = "";
    private string newLabelCategoryStr = "";
    private string newCategoryName = "";
    private string? labelError;
    private string? categoryError;

    private Guid? NewLabelCategoryId =>
        Guid.TryParse(newLabelCategoryStr, out var g) && g != Guid.Empty ? g : null;

    protected override async Task OnParametersSetAsync()
    {
        if (_currentId == Id && _currentParentId == ParentId) return;
        _currentId = Id;
        _currentParentId = ParentId;

        title = string.Empty;
        content = string.Empty;
        archivedAt = null;
        parentNoteId = null;
        parentTitle = null;
        childCount = 0;
        noteLabels = [];
        _contentJustLoaded = true;
        _hasConflict = false;
        _isSaving = false;
        _serverUpdatedAt = default;

        if (Id is not null)
        {
            var result = await NoteService.GetAsync(Id.Value);
            if (result.IsSuccess)
            {
                title = result.Value!.Title;
                content = result.Value!.Content;
                archivedAt = result.Value!.ArchivedAt;
                noteLabels = result.Value!.Labels ?? [];
                parentNoteId = result.Value!.ParentNoteId;
                parentTitle = result.Value!.ParentTitle;
                childCount = result.Value!.ChildCount;
                _serverUpdatedAt = result.Value!.UpdatedAt;

                // Record the visit for Quick Navigation Recents (client-side only, FR-9/§6.6).
                await QuickNav.PushRecentAsync(new RecentNote
                {
                    Id = result.Value!.Id,
                    Title = result.Value!.Title,
                    IsArchived = archivedAt is not null,
                    VisitedAt = DateTime.UtcNow
                });
            }
            else
            {
                // A stale Recents entry can point at a deleted note (E3/E4) — prune it.
                await QuickNav.RemoveRecentAsync(Id.Value);
                Snackbar.Add("That note no longer exists.", Severity.Error);
                Nav.NavigateTo("/");
                return;
            }
        }
        else if (ParentId.HasValue)
        {
            parentNoteId = ParentId;
            var parentResult = await NoteService.GetAsync(ParentId.Value);
            if (parentResult.IsSuccess)
                parentTitle = parentResult.Value!.Title;
        }

        await LoadLabelsAsync();
    }

    private async Task LoadLabelsAsync()
    {
        var labelsResult = await LabelService.GetLabelsAsync();
        if (!labelsResult.IsSuccess)
            Snackbar.Add(labelsResult.Error ?? "Failed to load labels.", Severity.Warning);
        availableLabels = labelsResult.Value ?? [];

        var categoriesResult = await LabelService.GetCategoriesAsync();
        if (!categoriesResult.IsSuccess)
            Snackbar.Add(categoriesResult.Error ?? "Failed to load categories.", Severity.Warning);
        labelCategories = categoriesResult.Value ?? [];
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            var apiBase = Http.BaseAddress?.ToString().TrimEnd('/') ?? string.Empty;
            var token = await TokenStore.GetAsync() ?? string.Empty;
            try
            {
                await JS.InvokeVoidAsync("tiptapInterop.init", _editorId, _objRef, content, apiBase, token, !IsArchived);
                _editorMounted = true;
                await ShortcutService.RegisterAsync("ctrl+s", "Save note", () => InvokeAsync(SaveNote));
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to initialize Tiptap editor for element '{EditorId}'.", _editorId);
            }
        }
        else if (_contentJustLoaded && _editorMounted)
        {
            _contentJustLoaded = false;
            await JS.InvokeVoidAsync("tiptapInterop.setContent", _editorId, content);
            await JS.InvokeVoidAsync("tiptapInterop.setEditable", _editorId, !IsArchived);
        }
    }

    [JSInvokable]
    public void OnEditorContentChanged(string html)
    {
        content = html;
        ScheduleAutoSave();
    }

    private void OnTitleInput(ChangeEventArgs e)
    {
        title = e.Value?.ToString() ?? string.Empty;
        ScheduleAutoSave();
    }

    private async Task OnTitleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await JS.InvokeVoidAsync("tiptapInterop.focus", _editorId);
    }

    private void ScheduleAutoSave()
    {
        if (_hasConflict || IsArchived) return;
        _hasPendingChanges = true;
        SetStatus("Writing...", "status-pending");
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = new CancellationTokenSource();
        _ = DebounceAndSave(_debounceCts.Token);
    }

    private async Task DebounceAndSave(CancellationToken token)
    {
        try
        {
            await Task.Delay(1500, token);
            await InvokeAsync(DoAutoSave);
        }
        catch (TaskCanceledException) { }
    }

    private async Task<NoteItem?> SaveCoreAsync()
    {
        var note = new NoteItem
        {
            Id = Id ?? Guid.Empty,
            Title = title,
            Content = content,
            ParentNoteId = parentNoteId,
            UpdatedAt = _serverUpdatedAt
        };
        var result = await NoteService.SaveAsync(note);
        if (result.IsConflict)
        {
            _hasConflict = true;
            return null;
        }
        if (result.IsForbidden)
        {
            // The note was archived by another session — switch to read-only mode.
            await EnterArchivedModeAsync();
            return null;
        }
        if (!result.IsSuccess)
        {
            Logger.LogError("Save failed for note {NoteId}.", note.Id);
            return null;
        }
        _serverUpdatedAt = result.Value!.UpdatedAt;
        _hasPendingChanges = false;
        return result.Value;
    }

    private async Task DoAutoSave()
    {
        if (_isSaving) return;
        _isSaving = true;

        try
        {
            SetStatus("Saving...", "status-saving");
            StateHasChanged();

            var saved = await SaveCoreAsync();
            if (saved is null)
            {
                SetStatus(_hasConflict ? "Conflict" : IsArchived ? "Archived" : "Save failed", "status-error");
                StateHasChanged();
                return;
            }

            if (isNew && !_isDisposing)
            {
                foreach (var label in noteLabels.ToList())
                    await LabelService.AddLabelToNoteAsync(saved.Id, label.Id);
                // Set _currentId/_currentParentId before navigating so OnParametersSetAsync
                // treats this as a same-note transition and skips the full state reset,
                // preserving any content the user typed during the network round-trip.
                _currentId = saved.Id;
                _currentParentId = null;
                Nav.NavigateTo($"/editor/{saved.Id}", replace: true);
            }

            SetStatus("Saved", "status-saved");
            StateHasChanged();

            await Task.Delay(2000);
            SetStatus(string.Empty, string.Empty);
            StateHasChanged();
        }
        finally
        {
            _isSaving = false;
        }

        // Save any changes that arrived while this save was in flight
        if (_hasPendingChanges && !_hasConflict && !_isDisposing)
            ScheduleAutoSave();
    }

    private void SetStatus(string text, string css)
    {
        saveStatusText = text;
        saveStatusCss = css;
    }

    private async Task SaveNote()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = null;

        var saved = await SaveCoreAsync();
        if (saved is null)
        {
            if (!_hasConflict && !IsArchived)
                Snackbar.Add("Failed to save note.", Severity.Error);
            else
                StateHasChanged();
            return;
        }
        if (isNew)
        {
            foreach (var label in noteLabels.ToList())
                await LabelService.AddLabelToNoteAsync(saved.Id, label.Id);
        }
        Nav.NavigateTo(BackUrl);
    }

    private async Task ForceSave()
    {
        _serverUpdatedAt = default;
        _hasConflict = false;
        _hasPendingChanges = true;
        await DoAutoSave();
    }

    private async Task ReloadNote()
    {
        if (Id is null) { Nav.NavigateTo("/"); return; }
        var result = await NoteService.GetAsync(Id.Value);
        if (!result.IsSuccess) { Nav.NavigateTo("/"); return; }
        title = result.Value!.Title;
        content = result.Value!.Content;
        noteLabels = result.Value!.Labels ?? [];
        _serverUpdatedAt = result.Value!.UpdatedAt;
        _hasConflict = false;
        _hasPendingChanges = false;
        SetStatus(string.Empty, string.Empty);
        await JS.InvokeVoidAsync("tiptapInterop.setContent", _editorId, content);
        StateHasChanged();
    }

    private async Task DeleteNote()
    {
        _debounceCts?.Cancel();
        if (Id is not null)
        {
            var parts = new List<string>();
            if (childCount > 0)
                parts.Add($"This note has {childCount} sub-note(s) that will be moved to the Recycle Bin too.");

            if (parts.Count > 0)
            {
                parts.Add("Move this note to the Recycle Bin? Items in the Recycle Bin are deleted permanently after 30 days.");
                var confirmed = await JS.InvokeAsync<bool>("confirm", string.Join("\n\n", parts));
                if (!confirmed) return;
            }

            var noteId = Id.Value;
            var result = await NoteService.DeleteAsync(noteId);
            if (!result.IsSuccess)
            {
                Snackbar.Add(result.Error ?? "Failed to delete note.", Severity.Error);
                return;
            }

            Snackbar.Add("Note moved to the Recycle Bin.", Severity.Normal, config =>
            {
                config.Action = "Undo";
                config.ActionColor = Color.Primary;
                config.OnClick = async _ => await NoteService.RestoreAsync(noteId);
            });
        }
        Nav.NavigateTo("/");
    }

    private void CreateSubNote() => Nav.NavigateTo($"/editor?parentId={Id}");

    // ── Archive actions ───────────────────────────────────────────────────────

    /// <summary>Switches the open editor to read-only mode after the server
    /// reported the note as archived (403 on save from another session).</summary>
    private async Task EnterArchivedModeAsync()
    {
        if (IsArchived) return;
        archivedAt = DateTime.UtcNow; // marker only; the server holds the real value
        _hasPendingChanges = false;
        _debounceCts?.Cancel();
        Snackbar.Add("This note has been archived and is now read-only.", Severity.Warning);
        if (_editorMounted)
            await JS.InvokeVoidAsync("tiptapInterop.setEditable", _editorId, false);
        StateHasChanged();
    }

    private async Task ArchiveNote()
    {
        if (Id is null) return;

        var confirmed = await JS.InvokeAsync<bool>("confirm",
            "Archive this note? Sub-notes will be archived too. Archived notes are read-only and kept indefinitely.");
        if (!confirmed) return;

        // Flush any pending edits before the note becomes read-only.
        _debounceCts?.Cancel();
        if (_hasPendingChanges)
            await SaveCoreAsync();

        var noteId = Id.Value;
        var result = await NoteService.ArchiveAsync(noteId);
        if (!result.IsSuccess)
        {
            Snackbar.Add(result.Error ?? "Failed to archive note.", Severity.Error);
            return;
        }

        _hasPendingChanges = false;
        Snackbar.Add("Note archived.", Severity.Normal, config =>
        {
            config.Action = "Undo";
            config.ActionColor = Color.Primary;
            config.OnClick = async _ => await NoteService.UnarchiveAsync(noteId);
        });
        Nav.NavigateTo(BackUrl);
    }

    private async Task UnarchiveNote()
    {
        if (Id is null) return;

        var result = await NoteService.UnarchiveAsync(Id.Value);
        if (!result.IsSuccess)
        {
            Snackbar.Add(result.Error ?? "Failed to unarchive note.", Severity.Error);
            return;
        }

        archivedAt = null;
        if (_editorMounted)
            await JS.InvokeVoidAsync("tiptapInterop.setEditable", _editorId, true);
        Snackbar.Add("Note unarchived.", Severity.Success);
        StateHasChanged();
    }

    [JSInvokable]
    public async Task<PageLinkDto?> OnSlashCommandPage()
    {
        if (!Id.HasValue) return null;
        var result = await NoteService.SaveAsync(new NoteItem
        {
            Id = Guid.Empty,
            Title = "Untitled",
            ParentNoteId = Id,
        });
        if (!result.IsSuccess) return null;
        return new PageLinkDto(result.Value!.Id, result.Value!.Title);
    }

    [JSInvokable]
    public async Task OnPageLinkClick(string noteId)
    {
        if (!Guid.TryParse(noteId, out var id)) return;
        var parameters = new DialogParameters<SubNoteDialog> { { x => x.NoteId, id } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<SubNoteDialog>(string.Empty, parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: string newTitle })
        {
            var newContent = await JS.InvokeAsync<string>("tiptapInterop.updatePageLink", _editorId, noteId, newTitle);
            if (!string.IsNullOrEmpty(newContent))
            {
                content = newContent;
                _debounceCts?.Cancel();
                await DoAutoSave();
            }
        }
    }

    [JSInvokable]
    public async Task<List<JsMentionItem>> SearchNotes(string query)
    {
        var result = await NoteService.SearchForMentionAsync(query);
        if (!result.IsSuccess) return [];
        return result.Value!
            .Where(n => n.Id != Id.GetValueOrDefault())
            .Select(n => new JsMentionItem(
                n.Id.ToString(),
                string.IsNullOrWhiteSpace(n.Title) ? "(Untitled)" : n.Title))
            .ToList();
    }

    [JSInvokable]
    public async Task OnMentionClick(string noteId)
    {
        if (!Guid.TryParse(noteId, out var id)) return;
        var parameters = new DialogParameters<SubNoteDialog> { { x => x.NoteId, id } };
        var options = new DialogOptions { MaxWidth = MaxWidth.Large, FullWidth = true, CloseOnEscapeKey = true };
        var dialog = await DialogService.ShowAsync<SubNoteDialog>(string.Empty, parameters, options);
        var result = await dialog.Result;
        if (result is { Canceled: false, Data: string newTitle })
        {
            var newContent = await JS.InvokeAsync<string?>("tiptapInterop.updateMentionTitle", _editorId, noteId, newTitle);
            if (!string.IsNullOrEmpty(newContent))
            {
                content = newContent;
                _debounceCts?.Cancel();
                await DoAutoSave();
            }
        }
    }

    public record PageLinkDto(
        [property: JsonPropertyName("id")] Guid Id,
        [property: JsonPropertyName("title")] string Title
    );

    public record JsMentionItem(
        [property: JsonPropertyName("id")] string Id,
        [property: JsonPropertyName("title")] string Title
    );

    private async Task ExportMarkdown()
    {
        var safeName = string.IsNullOrWhiteSpace(title) ? "note" : title.Trim();
        foreach (var c in Path.GetInvalidFileNameChars())
            safeName = safeName.Replace(c, '_');
        await JS.InvokeVoidAsync("tiptapInterop.downloadMarkdown", _editorId, $"{safeName}.md");
    }

    private void GoBack()
    {
        Nav.NavigateTo(BackUrl);
    }

    // ── Label actions ─────────────────────────────────────────────────────────

    private void ToggleLabelPicker()
    {
        showLabelPicker = !showLabelPicker;
        if (showLabelPicker) showLabelManager = false;
    }

    private void CloseLabelPicker()
    {
        showLabelPicker = false;
    }

    private void ToggleLabelManager()
    {
        showLabelManager = !showLabelManager;
        showLabelPicker = false;
    }

    private async Task ToggleLabel(Label label)
    {
        if (noteLabels.Any(l => l.Id == label.Id))
        {
            if (Id is not null)
            {
                var result = await LabelService.RemoveLabelFromNoteAsync(Id.Value, label.Id);
                if (!result.IsSuccess)
                {
                    Snackbar.Add(result.Error ?? "Failed to remove label.", Severity.Warning);
                    return;
                }
            }
            noteLabels.RemoveAll(l => l.Id == label.Id);
        }
        else
        {
            if (Id is not null)
            {
                var result = await LabelService.AddLabelToNoteAsync(Id.Value, label.Id);
                if (!result.IsSuccess)
                {
                    Snackbar.Add(result.Error ?? "Failed to add label.", Severity.Warning);
                    return;
                }
            }

            // Apply category exclusivity in local state
            if (label.CategoryId.HasValue)
                noteLabels.RemoveAll(l => l.CategoryId == label.CategoryId);

            noteLabels.Add(label);
            noteLabels = [.. noteLabels.OrderBy(l => l.Name)];
        }
    }

    private async Task RemoveLabel(Guid labelId)
    {
        if (Id is not null)
        {
            var result = await LabelService.RemoveLabelFromNoteAsync(Id.Value, labelId);
            if (!result.IsSuccess)
            {
                Snackbar.Add(result.Error ?? "Failed to remove label.", Severity.Warning);
                return;
            }
        }
        noteLabels.RemoveAll(l => l.Id == labelId);
    }

    private async Task CreateLabel()
    {
        if (string.IsNullOrWhiteSpace(newLabelName)) return;
        var result = await LabelService.CreateLabelAsync(newLabelName.Trim(), NewLabelCategoryId);
        if (!result.IsSuccess)
        {
            labelError = result.Error;
            return;
        }
        labelError = null;
        availableLabels.Add(result.Value!);
        availableLabels = [.. availableLabels.OrderBy(l => l.Name)];
        newLabelName = "";
        newLabelCategoryStr = "";
    }

    private async Task CreateCategory()
    {
        if (string.IsNullOrWhiteSpace(newCategoryName)) return;
        var result = await LabelService.CreateCategoryAsync(newCategoryName.Trim());
        if (!result.IsSuccess)
        {
            categoryError = result.Error;
            return;
        }
        categoryError = null;
        labelCategories.Add(result.Value!);
        labelCategories = [.. labelCategories.OrderBy(c => c.Name)];
        newCategoryName = "";
    }

    private async Task DeleteLabel(Guid labelId)
    {
        var result = await LabelService.DeleteLabelAsync(labelId);
        if (!result.IsSuccess)
        {
            Snackbar.Add(result.Error ?? "Failed to delete label.", Severity.Error);
            return;
        }
        availableLabels.RemoveAll(l => l.Id == labelId);
        noteLabels.RemoveAll(l => l.Id == labelId);
    }

    private async Task DeleteCategory(Guid categoryId)
    {
        var result = await LabelService.DeleteCategoryAsync(categoryId);
        if (!result.IsSuccess)
        {
            Snackbar.Add(result.Error ?? "Failed to delete category.", Severity.Error);
            return;
        }
        var removedIds = availableLabels
            .Where(l => l.CategoryId == categoryId)
            .Select(l => l.Id)
            .ToHashSet();
        availableLabels.RemoveAll(l => l.CategoryId == categoryId);
        noteLabels.RemoveAll(l => removedIds.Contains(l.Id));
        labelCategories.RemoveAll(c => c.Id == categoryId);
    }

    public async ValueTask DisposeAsync()
    {
        _isDisposing = true;
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();

        if (_hasPendingChanges && !_hasConflict && !IsArchived)
            await SaveCoreAsync();

        _objRef?.Dispose();
        await ShortcutService.UnregisterAsync("ctrl+s");
        if (_editorMounted)
            await JS.InvokeVoidAsync("tiptapInterop.destroy", _editorId);
    }
}
