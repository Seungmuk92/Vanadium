@page "/editor"
@page "/editor/{Id:guid}"
@attribute [Authorize]
@inject NoteService NoteService
@inject LabelService LabelService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject HttpClient Http
@inject TokenStore TokenStore
@inject ILogger<NoteEditor> Logger
@inject ISnackbar Snackbar
@implements IDisposable

<PageTitle>@(isNew ? "New Note" : "Edit Note")</PageTitle>

<div class="editor-header">
    <button class="btn btn-outline-secondary" @onclick="GoBack">← Back</button>
    @if (parentNoteId.HasValue || parentTitle is not null)
    {
        <div class="editor-breadcrumb">
            <a href="/">Notes</a>
            <span class="breadcrumb-sep">/</span>
            <a href="/editor/@parentNoteId">@(string.IsNullOrWhiteSpace(parentTitle) ? "(Untitled)" : parentTitle)</a>
        </div>
    }
    <span class="save-status @saveStatusCss">@saveStatusText</span>
    <div class="editor-actions">
        @if (!isNew)
        {
            <button class="btn btn-outline-secondary" @onclick="CreateSubNote">+ Sub-note</button>
            <button class="btn btn-outline-danger" @onclick="DeleteNote">Delete</button>
        }
        <button class="btn btn-primary" @onclick="SaveNote">Save</button>
    </div>
</div>

<div class="editor-body">
    <input class="editor-title"
           type="text"
           placeholder="Title"
           value="@title"
           @oninput="OnTitleInput"
           @onkeydown="OnTitleKeyDown" />

    <div class="label-bar">
        @foreach (var label in noteLabels)
        {
            <span class="label-chip @(label.CategoryId.HasValue ? "label-chip-cat" : "")">
                @if (label.CategoryId.HasValue)
                {
                    <span class="label-cat-prefix">@label.CategoryName:</span>
                }
                <span>@label.Name</span>
                <button class="label-chip-remove" @onclick="() => RemoveLabel(label.Id)">×</button>
            </span>
        }

        <div class="label-add-wrapper">
            <button class="label-add-btn @(showLabelPicker ? "label-add-btn-active" : "")" @onclick="ToggleLabelPicker">
                + Label
            </button>

            @if (showLabelPicker)
            {
                <div class="label-picker-backdrop" @onclick="CloseLabelPicker"></div>
                <div class="label-picker">
                    @{
                        var generalLabels = availableLabels.Where(l => !l.CategoryId.HasValue).ToList();
                    }

                    @if (generalLabels.Any())
                    {
                        <div class="label-picker-section">
                            <div class="label-picker-section-title">General</div>
                            @foreach (var lbl in generalLabels)
                            {
                                var isAdded = noteLabels.Any(nl => nl.Id == lbl.Id);
                                <div class="label-picker-item @(isAdded ? "is-added" : "")" @onclick="() => ToggleLabel(lbl)">
                                    <span class="label-picker-check">@(isAdded ? "✓" : "")</span>
                                    <span>@lbl.Name</span>
                                </div>
                            }
                        </div>
                    }

                    @foreach (var cat in labelCategories)
                    {
                        var catLabels = availableLabels.Where(l => l.CategoryId == cat.Id).ToList();
                        if (!catLabels.Any()) continue;
                        <div class="label-picker-section">
                            <div class="label-picker-section-title">@cat.Name</div>
                            @foreach (var lbl in catLabels)
                            {
                                var isAdded = noteLabels.Any(nl => nl.Id == lbl.Id);
                                <div class="label-picker-item @(isAdded ? "is-added" : "")" @onclick="() => ToggleLabel(lbl)">
                                    <span class="label-picker-check">@(isAdded ? "✓" : "")</span>
                                    <span>@lbl.Name</span>
                                </div>
                            }
                        </div>
                    }

                    @if (!availableLabels.Any())
                    {
                        <div class="label-picker-empty">No labels</div>
                    }

                    <div class="label-picker-divider"></div>
                    <div class="label-picker-manage-btn" @onclick="ToggleLabelManager">Manage labels...</div>
                </div>
            }
        </div>
    </div>

    @if (showLabelManager)
    {
        <div class="label-manager">
            <div class="label-manager-header">
                <strong>Manage Labels</strong>
                <button class="btn btn-sm btn-outline-secondary" @onclick="ToggleLabelManager">Close</button>
            </div>
            <div class="label-manager-body">
                <div class="label-manager-section">
                    <div class="label-manager-section-title">Categories</div>
                    @foreach (var cat in labelCategories)
                    {
                        <div class="label-manager-item">
                            <span>@cat.Name</span>
                            <button class="label-mgr-delete" @onclick="() => DeleteCategory(cat.Id)">×</button>
                        </div>
                    }
                    <div class="label-manager-new">
                        <input class="label-manager-input @(categoryError is not null ? "input-error" : "")"
                               @bind="newCategoryName"
                               @oninput="() => categoryError = null"
                               placeholder="Category name" />
                        <button class="btn btn-sm btn-primary" @onclick="CreateCategory">Add</button>
                    </div>
                    @if (categoryError is not null)
                    {
                        <div class="label-manager-error">@categoryError</div>
                    }
                </div>

                <div class="label-manager-section">
                    <div class="label-manager-section-title">Labels</div>
                    @foreach (var lbl in availableLabels)
                    {
                        <div class="label-manager-item">
                            <span>
                                @if (lbl.CategoryId.HasValue)
                                {
                                    <span class="label-mgr-cat-prefix">[@lbl.CategoryName]</span>
                                }
                                @lbl.Name
                            </span>
                            <button class="label-mgr-delete" @onclick="() => DeleteLabel(lbl.Id)">×</button>
                        </div>
                    }
                    <div class="label-manager-new">
                        <input class="label-manager-input @(labelError is not null ? "input-error" : "")"
                               @bind="newLabelName"
                               @oninput="() => labelError = null"
                               placeholder="Label name" />
                        <select class="label-manager-select" @bind="newLabelCategoryStr">
                            <option value="">General</option>
                            @foreach (var cat in labelCategories)
                            {
                                <option value="@cat.Id">@cat.Name</option>
                            }
                        </select>
                        <button class="btn btn-sm btn-primary" @onclick="CreateLabel">Add</button>
                    </div>
                    @if (labelError is not null)
                    {
                        <div class="label-manager-error">@labelError</div>
                    }
                </div>
            </div>
        </div>
    }

    <div id="@_editorId" class="tiptap-wrapper"></div>
</div>

@code {
    [Parameter] public Guid? Id { get; set; }
    [SupplyParameterFromQuery(Name = "returnUrl")] public string? ReturnUrl { get; set; }
    [SupplyParameterFromQuery(Name = "parentId")] public Guid? ParentId { get; set; }

    private string BackUrl
    {
        get
        {
            if (!string.IsNullOrWhiteSpace(ReturnUrl)) return ReturnUrl;
            if (parentNoteId.HasValue) return $"/editor/{parentNoteId}";
            return "/";
        }
    }

    private string title = string.Empty;
    private string content = string.Empty;
    private bool isNew => Id is null;
    private Guid? parentNoteId;
    private string? parentTitle;
    private int childCount;

    private bool _initialized = false;
    private bool _editorMounted = false;
    private bool _contentJustLoaded = false;
    private readonly string _editorId = "tiptap-" + Guid.NewGuid().ToString("N")[..8];
    private DotNetObjectReference<NoteEditor>? _objRef;
    private CancellationTokenSource? _debounceCts;
    private string saveStatusText = string.Empty;
    private string saveStatusCss = string.Empty;

    // Label state
    private List<Label> noteLabels = [];
    private List<Label> availableLabels = [];
    private List<LabelCategory> labelCategories = [];
    private bool showLabelPicker = false;
    private bool showLabelManager = false;
    private string newLabelName = "";
    private string newLabelCategoryStr = "";
    private string newCategoryName = "";
    private string? labelError;
    private string? categoryError;

    private Guid? NewLabelCategoryId =>
        Guid.TryParse(newLabelCategoryStr, out var g) && g != Guid.Empty ? g : null;

    protected override async Task OnParametersSetAsync()
    {
        if (_initialized) return;
        _initialized = true;

        if (Id is not null)
        {
            var result = await NoteService.GetAsync(Id.Value);
            if (result.IsSuccess)
            {
                title = result.Value!.Title;
                content = result.Value!.Content;
                noteLabels = result.Value!.Labels ?? [];
                parentNoteId = result.Value!.ParentNoteId;
                parentTitle = result.Value!.ParentTitle;
                childCount = result.Value!.ChildCount;
                _contentJustLoaded = true;
            }
            else
            {
                Snackbar.Add("Failed to load note.", Severity.Error);
                Nav.NavigateTo("/");
                return;
            }
        }
        else if (ParentId.HasValue)
        {
            parentNoteId = ParentId;
            var parentResult = await NoteService.GetAsync(ParentId.Value);
            if (parentResult.IsSuccess)
                parentTitle = parentResult.Value!.Title;
        }

        await LoadLabelsAsync();
    }

    private async Task LoadLabelsAsync()
    {
        var labelsResult = await LabelService.GetLabelsAsync();
        if (!labelsResult.IsSuccess)
            Snackbar.Add(labelsResult.Error ?? "Failed to load labels.", Severity.Warning);
        availableLabels = labelsResult.Value ?? [];

        var categoriesResult = await LabelService.GetCategoriesAsync();
        if (!categoriesResult.IsSuccess)
            Snackbar.Add(categoriesResult.Error ?? "Failed to load categories.", Severity.Warning);
        labelCategories = categoriesResult.Value ?? [];
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _objRef = DotNetObjectReference.Create(this);
            var apiBase = Http.BaseAddress?.ToString().TrimEnd('/') ?? string.Empty;
            var token = await TokenStore.GetAsync() ?? string.Empty;
            try
            {
                await JS.InvokeVoidAsync("tiptapInterop.init", _editorId, _objRef, content, apiBase, token);
                _editorMounted = true;
            }
            catch (Exception ex)
            {
                Logger.LogError(ex, "Failed to initialize Tiptap editor for element '{EditorId}'.", _editorId);
            }
        }
        else if (_contentJustLoaded && _editorMounted)
        {
            _contentJustLoaded = false;
            await JS.InvokeVoidAsync("tiptapInterop.setContent", _editorId, content);
        }
    }

    [JSInvokable]
    public void OnEditorContentChanged(string html)
    {
        content = html;
        ScheduleAutoSave();
    }

    [JSInvokable]
    public async Task OnSaveShortcut()
    {
        await InvokeAsync(SaveNote);
    }

    private void OnTitleInput(ChangeEventArgs e)
    {
        title = e.Value?.ToString() ?? string.Empty;
        ScheduleAutoSave();
    }

    private async Task OnTitleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
            await JS.InvokeVoidAsync("tiptapInterop.focus", _editorId);
    }

    private void ScheduleAutoSave()
    {
        SetStatus("Writing...", "status-pending");
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _debounceCts = new CancellationTokenSource();
        _ = DebounceAndSave(_debounceCts.Token);
    }

    private async Task DebounceAndSave(CancellationToken token)
    {
        try
        {
            await Task.Delay(1500, token);
            await InvokeAsync(DoAutoSave);
        }
        catch (TaskCanceledException) { }
    }

    private async Task DoAutoSave()
    {
        SetStatus("Saving...", "status-saving");
        StateHasChanged();

        var note = new NoteItem
        {
            Id = Id ?? Guid.Empty,
            Title = title,
            Content = content,
            ParentNoteId = parentNoteId
        };

        var saveResult = await NoteService.SaveAsync(note);

        if (!saveResult.IsSuccess)
        {
            Logger.LogError("Auto-save failed for note {NoteId}.", note.Id);
            SetStatus("Save failed", "status-error");
            StateHasChanged();
            return;
        }

        if (isNew)
        {
            foreach (var label in noteLabels.ToList())
                await LabelService.AddLabelToNoteAsync(saveResult.Value!.Id, label.Id);
            Nav.NavigateTo($"/editor/{saveResult.Value!.Id}", replace: true);
        }

        SetStatus("Saved", "status-saved");
        StateHasChanged();

        await Task.Delay(2000);
        SetStatus(string.Empty, string.Empty);
        StateHasChanged();
    }

    private void SetStatus(string text, string css)
    {
        saveStatusText = text;
        saveStatusCss = css;
    }

    private async Task SaveNote()
    {
        _debounceCts?.Cancel();
        var note = new NoteItem
        {
            Id = Id ?? Guid.Empty,
            Title = title,
            Content = content,
            ParentNoteId = parentNoteId
        };
        var saveResult = await NoteService.SaveAsync(note);
        if (!saveResult.IsSuccess)
        {
            Snackbar.Add(saveResult.Error ?? "Failed to save note.", Severity.Error);
            return;
        }
        if (isNew)
        {
            foreach (var label in noteLabels.ToList())
                await LabelService.AddLabelToNoteAsync(saveResult.Value!.Id, label.Id);
        }
        Nav.NavigateTo(BackUrl);
    }

    private async Task DeleteNote()
    {
        _debounceCts?.Cancel();
        if (Id is not null)
        {
            if (childCount > 0)
            {
                var confirmed = await JS.InvokeAsync<bool>("confirm",
                    $"This note has {childCount} sub-note(s) that will also be permanently deleted. Continue?");
                if (!confirmed) return;
            }

            var result = await NoteService.DeleteAsync(Id.Value);
            if (!result.IsSuccess)
            {
                Snackbar.Add(result.Error ?? "Failed to delete note.", Severity.Error);
                return;
            }
        }
        Nav.NavigateTo(parentNoteId.HasValue ? $"/editor/{parentNoteId}" : "/");
    }

    private void CreateSubNote() => Nav.NavigateTo($"/editor?parentId={Id}");

    private void GoBack()
    {
        Nav.NavigateTo(BackUrl);
    }

    // ── Label actions ─────────────────────────────────────────────────────────

    private void ToggleLabelPicker()
    {
        showLabelPicker = !showLabelPicker;
        if (showLabelPicker) showLabelManager = false;
    }

    private void CloseLabelPicker()
    {
        showLabelPicker = false;
    }

    private void ToggleLabelManager()
    {
        showLabelManager = !showLabelManager;
        showLabelPicker = false;
    }

    private async Task ToggleLabel(Label label)
    {
        if (noteLabels.Any(l => l.Id == label.Id))
        {
            if (Id is not null)
            {
                var result = await LabelService.RemoveLabelFromNoteAsync(Id.Value, label.Id);
                if (!result.IsSuccess)
                {
                    Snackbar.Add(result.Error ?? "Failed to remove label.", Severity.Warning);
                    return;
                }
            }
            noteLabels.RemoveAll(l => l.Id == label.Id);
        }
        else
        {
            if (Id is not null)
            {
                var result = await LabelService.AddLabelToNoteAsync(Id.Value, label.Id);
                if (!result.IsSuccess)
                {
                    Snackbar.Add(result.Error ?? "Failed to add label.", Severity.Warning);
                    return;
                }
            }

            // Apply category exclusivity in local state
            if (label.CategoryId.HasValue)
                noteLabels.RemoveAll(l => l.CategoryId == label.CategoryId);

            noteLabels.Add(label);
            noteLabels = [.. noteLabels.OrderBy(l => l.Name)];
        }
    }

    private async Task RemoveLabel(Guid labelId)
    {
        if (Id is not null)
        {
            var result = await LabelService.RemoveLabelFromNoteAsync(Id.Value, labelId);
            if (!result.IsSuccess)
            {
                Snackbar.Add(result.Error ?? "Failed to remove label.", Severity.Warning);
                return;
            }
        }
        noteLabels.RemoveAll(l => l.Id == labelId);
    }

    private async Task CreateLabel()
    {
        if (string.IsNullOrWhiteSpace(newLabelName)) return;
        var result = await LabelService.CreateLabelAsync(newLabelName.Trim(), NewLabelCategoryId);
        if (!result.IsSuccess)
        {
            labelError = result.Error;
            return;
        }
        labelError = null;
        availableLabels.Add(result.Value!);
        availableLabels = [.. availableLabels.OrderBy(l => l.Name)];
        newLabelName = "";
        newLabelCategoryStr = "";
    }

    private async Task CreateCategory()
    {
        if (string.IsNullOrWhiteSpace(newCategoryName)) return;
        var result = await LabelService.CreateCategoryAsync(newCategoryName.Trim());
        if (!result.IsSuccess)
        {
            categoryError = result.Error;
            return;
        }
        categoryError = null;
        labelCategories.Add(result.Value!);
        labelCategories = [.. labelCategories.OrderBy(c => c.Name)];
        newCategoryName = "";
    }

    private async Task DeleteLabel(Guid labelId)
    {
        var result = await LabelService.DeleteLabelAsync(labelId);
        if (!result.IsSuccess)
        {
            Snackbar.Add(result.Error ?? "Failed to delete label.", Severity.Error);
            return;
        }
        availableLabels.RemoveAll(l => l.Id == labelId);
        noteLabels.RemoveAll(l => l.Id == labelId);
    }

    private async Task DeleteCategory(Guid categoryId)
    {
        var result = await LabelService.DeleteCategoryAsync(categoryId);
        if (!result.IsSuccess)
        {
            Snackbar.Add(result.Error ?? "Failed to delete category.", Severity.Error);
            return;
        }
        var removedIds = availableLabels
            .Where(l => l.CategoryId == categoryId)
            .Select(l => l.Id)
            .ToHashSet();
        availableLabels.RemoveAll(l => l.CategoryId == categoryId);
        noteLabels.RemoveAll(l => removedIds.Contains(l.Id));
        labelCategories.RemoveAll(c => c.Id == categoryId);
    }

    public void Dispose()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _objRef?.Dispose();
        if (_editorMounted)
            JS.InvokeVoidAsync("tiptapInterop.destroy", _editorId);
    }
}
