@page "/board"
@attribute [Authorize]
@inject NoteService NoteService
@inject LabelService LabelService
@inject NavigationManager Nav
@inject IJSRuntime JS
@inject ILogger<Board> Logger
@inject ISnackbar Snackbar
@implements IAsyncDisposable

<PageTitle>Board</PageTitle>

<div class="board-page">
    <div class="board-top-bar">
        <div class="board-category-selector">
            <span class="board-cat-label">Category:</span>
            @if (!categories.Any())
            {
                <span class="board-no-categories">No categories yet. Create one in the note editor.</span>
            }
            else
            {
                @foreach (var cat in categories)
                {
                    var catId = cat.Id;
                    <button class="board-cat-btn @(selectedCategoryId == catId ? "active" : "")"
                            @onclick="() => SelectCategory(catId)">
                        @cat.Name
                    </button>
                }
            }
        </div>
    </div>

    @if (isLoading && !notes.Any())
    {
        <p class="board-loading-msg">Loading...</p>
    }
    else if (selectedCategory is null || !selectedCategory.Labels.Any())
    {
        <p class="board-empty-msg">
            @if (!categories.Any())
            {
                <span>No categories found. Create a label category in the note editor first.</span>
            }
            else
            {
                <span>This category has no labels.</span>
            }
        </p>
    }
    else
    {
        <div class="board-columns">
            @foreach (var label in selectedCategory.Labels.OrderBy(l => l.Name))
            {
                var columnLabel = label;
                var notesForLabel = GetNotesForLabel(columnLabel.Id);
                var isExpanded = expandedColumns.Contains(columnLabel.Id);
                var visibleNotes = isExpanded ? notesForLabel : notesForLabel.Take(CardsPerColumnLimit).ToList();
                var hiddenCount = notesForLabel.Count - visibleNotes.Count;

                <div class="board-column"
                     data-label-id="@columnLabel.Id">
                    <div class="board-column-header">
                        <span class="board-column-title">@columnLabel.Name</span>
                        <span class="board-column-count">@notesForLabel.Count</span>
                    </div>
                    <div class="board-column-cards">
                        @foreach (var note in visibleNotes)
                        {
                            var capturedNote = note;
                            <div class="board-card"
                                 draggable="true"
                                 data-note-id="@capturedNote.Id"
                                 data-label-id="@columnLabel.Id"
                                 @onclick="() => EditNote(capturedNote.Id)">
                                <div class="board-card-title">
                                    @(string.IsNullOrWhiteSpace(capturedNote.Title) ? "(No title)" : capturedNote.Title)
                                </div>
                                @{
                                    var otherLabels = capturedNote.Labels.Where(l => l.Id != columnLabel.Id).ToList();
                                }
                                @if (otherLabels.Any())
                                {
                                    <div class="board-card-labels">
                                        @foreach (var lbl in otherLabels)
                                        {
                                            <span class="board-card-chip @(lbl.CategoryId.HasValue ? "board-card-chip-cat" : "")">
                                                @if (lbl.CategoryId.HasValue)
                                                {
                                                    <span class="board-card-chip-prefix">@lbl.CategoryName:</span>
                                                }
                                                @lbl.Name
                                            </span>
                                        }
                                    </div>
                                }
                                <div class="board-card-date">
                                    @capturedNote.UpdatedAt.ToLocalTime().ToString("MM-dd HH:mm")
                                </div>
                            </div>
                        }
                    </div>
                    @if (hiddenCount > 0)
                    {
                        <div class="board-column-showmore">
                            <button class="board-showmore-btn" @onclick="() => ShowMore(columnLabel.Id)">
                                Show @hiddenCount more
                            </button>
                        </div>
                    }
                    <div class="board-column-footer">
                        <button class="board-add-btn" @onclick="() => OpenAddDialog(columnLabel)">
                            + Add a note
                        </button>
                    </div>
                </div>
            }
        </div>
    }
</div>

@if (showDialog)
{
    <div class="board-dialog-overlay" @onclick="CancelDialog">
        <div class="board-dialog"
             role="dialog"
             aria-modal="true"
             aria-label="Add a note"
             @ref="_dialogRef"
             @onclick:stopPropagation="true">
            <div class="board-dialog-header">
                <h4>New note in &ldquo;<strong>@dialogLabel?.Name</strong>&rdquo;</h4>
                <button class="board-dialog-close" @onclick="CancelDialog">×</button>
            </div>
            <input class="board-dialog-input"
                   type="text"
                   placeholder="Note title"
                   @ref="_dialogInput"
                   @bind="newNoteTitle"
                   @bind:event="oninput"
                   @onkeydown="OnDialogKeyDown" />
            @if (string.IsNullOrWhiteSpace(newNoteTitle))
            {
                <div class="board-dialog-hint">Title is empty — will be saved as <em>(No title)</em></div>
            }
            @if (dialogError is not null)
            {
                <div class="board-dialog-error">@dialogError</div>
            }
            <div class="board-dialog-footer">
                <button class="btn btn-outline-secondary btn-sm" @onclick="CancelDialog" disabled="@isAdding">Cancel</button>
                <button class="btn btn-primary btn-sm" @onclick="ConfirmAddNote" disabled="@isAdding">
                    @(isAdding ? "Adding..." : "Add")
                </button>
            </div>
        </div>
    </div>
}

@code {
    // Cap the cards initially rendered per column so a category with many notes
    // does not grow the board's DOM/render cost without bound (#206). The rest
    // stay reachable behind a per-column "Show more" toggle.
    private const int CardsPerColumnLimit = 50;

    private IReadOnlyList<NoteSummary> notes = [];
    private List<LabelCategory> categories = [];
    private Guid? selectedCategoryId;
    private bool isLoading = false;
    // Label ids whose column has been expanded past CardsPerColumnLimit.
    private readonly HashSet<Guid> expandedColumns = [];
    private DotNetObjectReference<Board>? _dotNetRef;

    // ── Dialog state ──────────────────────────────────────────────────────────
    private bool showDialog = false;
    private Label? dialogLabel;
    private string newNoteTitle = "";
    private string? dialogError;
    private bool isAdding = false;
    private ElementReference _dialogRef;
    private ElementReference _dialogInput;
    private bool _trapQueued;

    private LabelCategory? selectedCategory =>
        categories.FirstOrDefault(c => c.Id == selectedCategoryId);

    protected override async Task OnInitializedAsync()
    {
        isLoading = true;
        var catResult = await LabelService.GetCategoriesAsync();
        if (!catResult.IsSuccess)
            Snackbar.Add(catResult.Error ?? "Failed to load categories.", Severity.Error);
        categories = catResult.Value ?? [];
        if (categories.Any())
        {
            selectedCategoryId = categories[0].Id;
            await LoadNotesForCurrentCategory();
        }
        isLoading = false;
    }

    private async Task LoadNotesForCurrentCategory()
    {
        // A fresh load collapses every column back to the cap.
        expandedColumns.Clear();
        if (selectedCategory is null || !selectedCategory.Labels.Any())
        {
            notes = [];
            isLoading = false;
            return;
        }
        isLoading = true;
        StateHasChanged();
        var labelIds = selectedCategory.Labels.Select(l => l.Id);
        var notesResult = await NoteService.GetAllSummariesAsync(labelIds);
        if (!notesResult.IsSuccess)
            Snackbar.Add(notesResult.Error ?? "Failed to load notes.", Severity.Error);
        notes = notesResult.Value ?? [];
        isLoading = false;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _dotNetRef = DotNetObjectReference.Create(this);
            await JS.InvokeVoidAsync("boardDragDrop.init", _dotNetRef);
        }

        if (_trapQueued)
        {
            _trapQueued = false;
            await JS.InvokeVoidAsync("focusTrap.activate", _dialogRef);
            try { await _dialogInput.FocusAsync(); } catch { /* dialog may have closed */ }
        }
    }

    // ── Called by JS when a card is dropped on a different column ─────────────

    [JSInvokable]
    public async Task OnDropFromJs(string noteIdStr, string fromLabelIdStr, string toLabelIdStr)
    {
        if (!Guid.TryParse(noteIdStr, out var noteId)) return;
        if (!Guid.TryParse(fromLabelIdStr, out var fromLabelId)) return;
        if (!Guid.TryParse(toLabelIdStr, out var toLabelId)) return;

        // Resolve target label object from current category
        var targetLabel = selectedCategory?.Labels.FirstOrDefault(l => l.Id == toLabelId);
        if (targetLabel is null)
        {
            Logger.LogWarning("Drop target label {LabelId} not found in current category.", toLabelId);
            return;
        }

        var note = notes.FirstOrDefault(n => n.Id == noteId);

        // Snapshot labels before mutation for rollback
        var originalLabels = note?.Labels.ToList();

        // Optimistic update — move card immediately
        if (note is not null)
        {
            note.Labels.RemoveAll(l => l.Id == fromLabelId);
            if (!note.Labels.Any(l => l.Id == toLabelId))
                note.Labels.Add(new Label
                {
                    Id = targetLabel.Id,
                    Name = targetLabel.Name,
                    CategoryId = targetLabel.CategoryId,
                    CategoryName = selectedCategory?.Name
                });
        }

        StateHasChanged();

        Logger.LogInformation("Moving note {NoteId}: label {FromLabel} → {ToLabel}.",
            noteId, fromLabelId, toLabelId);

        // Persist to server
        var removeResult = await LabelService.RemoveLabelFromNoteAsync(noteId, fromLabelId);
        var addResult = removeResult.IsSuccess
            ? await LabelService.AddLabelToNoteAsync(noteId, toLabelId)
            : ServiceResult<bool>.Fail("Remove failed");

        if (!removeResult.IsSuccess || !addResult.IsSuccess)
        {
            Logger.LogError(
                "Failed to persist label move for note {NoteId} ({FromLabel} → {ToLabel}).",
                noteId, fromLabelId, toLabelId);

            // Immediate visual rollback before server sync
            if (note is not null && originalLabels is not null)
            {
                note.Labels = originalLabels;
                StateHasChanged();
            }

            // Reload from server to guarantee UI matches DB
            await LoadNotesForCurrentCategory();
            Snackbar.Add("Failed to move note. Changes have been reverted.", Severity.Error);
        }
    }

    // ── General helpers ───────────────────────────────────────────────────────

    private List<NoteSummary> GetNotesForLabel(Guid labelId) =>
        notes.Where(n => n.Labels.Any(l => l.Id == labelId))
             .OrderByDescending(n => n.UpdatedAt)
             .ToList();

    private void ShowMore(Guid labelId) => expandedColumns.Add(labelId);

    private async Task SelectCategory(Guid catId)
    {
        selectedCategoryId = catId;
        await LoadNotesForCurrentCategory();
    }

    private void EditNote(Guid id) =>
        Nav.NavigateTo($"/editor/{id}?returnUrl=/board");

    // ── Add note dialog ───────────────────────────────────────────────────────

    private void OpenAddDialog(Label label)
    {
        dialogLabel = label;
        newNoteTitle = "";
        dialogError = null;
        isAdding = false;
        showDialog = true;
        _trapQueued = true;
    }

    private async Task CancelDialog()
    {
        if (isAdding) return;
        showDialog = false;
        dialogLabel = null;
        newNoteTitle = "";
        dialogError = null;
        await JS.InvokeVoidAsync("focusTrap.deactivate");
    }

    private async Task ConfirmAddNote()
    {
        if (dialogLabel is null || isAdding) return;

        isAdding = true;
        dialogError = null;
        StateHasChanged();

        try
        {
            var note = new NoteItem { Id = Guid.Empty, Title = newNoteTitle.Trim() };
            var saveResult = await NoteService.SaveAsync(note);
            if (saveResult.IsSuccess)
            {
                // The board places a new note into a column purely via its label. Ignoring the
                // label POST result left a saved-but-labelless note showing in no column, so it
                // looked like it vanished (#205). Detect the failure and tell the user the note
                // exists but was not added to the column.
                var labelResult = await LabelService.AddLabelToNoteAsync(saveResult.Value!.Id, dialogLabel.Id);
                if (!labelResult.IsSuccess)
                {
                    Logger.LogError(
                        "Note {NoteId} created but failed to add label '{LabelName}' from board dialog.",
                        saveResult.Value!.Id, dialogLabel.Name);
                    Snackbar.Add(
                        $"Note saved, but couldn't be added to \"{dialogLabel.Name}\". It won't appear on the board.",
                        Severity.Warning);
                }
                await LoadNotesForCurrentCategory();
                showDialog = false;
                dialogLabel = null;
                newNoteTitle = "";
                await JS.InvokeVoidAsync("focusTrap.deactivate");
            }
            else
            {
                Logger.LogError("Failed to create note from board dialog (label '{LabelName}').",
                    dialogLabel.Name);
                dialogError = "Failed to add note. Please try again.";
            }
        }
        catch (Exception ex)
        {
            Logger.LogError(ex, "Unexpected error creating note from board dialog.");
            dialogError = "Failed to add note. Please try again.";
        }
        finally
        {
            isAdding = false;
        }
    }

    private async Task OnDialogKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter") await ConfirmAddNote();
        else if (e.Key == "Escape") await CancelDialog();
    }

    public async ValueTask DisposeAsync()
    {
        if (showDialog)
            await JS.InvokeVoidAsync("focusTrap.deactivate");
        await JS.InvokeVoidAsync("boardDragDrop.dispose");
        _dotNetRef?.Dispose();
    }
}
