@page "/settings"
@attribute [Authorize]
@inject SettingsService SettingsService
@inject ApiTokenService ApiTokenService
@inject ThemeService ThemeService
@inject ISnackbar Snackbar
@inject IJSRuntime JS
@inject IDialogService DialogService

<PageTitle>Settings</PageTitle>

<div class="settings-page">
    <h1>Settings</h1>

    @if (_isLoading)
    {
        <p class="empty-message">Loading...</p>
    }
    else
    {
        <div class="settings-section">
            <h2 class="settings-section-title">Appearance</h2>

            <div class="settings-row">
                <label class="settings-label">Theme</label>
                <MudSelect T="string"
                           Value="_settings.Theme"
                           ValueChanged="v => _settings.Theme = v"
                           Dense="true"
                           Variant="Variant.Outlined"
                           Class="settings-select">
                    <MudSelectItem Value="@("system")">System default</MudSelectItem>
                    <MudSelectItem Value="@("light")">Light</MudSelectItem>
                    <MudSelectItem Value="@("dark")">Dark</MudSelectItem>
                </MudSelect>
            </div>
        </div>

        <div class="settings-section">
            <h2 class="settings-section-title">Notes List</h2>

            <div class="settings-row">
                <label class="settings-label">Default sort by</label>
                <MudSelect T="string"
                           Value="_settings.DefaultSortBy"
                           ValueChanged="v => _settings.DefaultSortBy = v"
                           Dense="true"
                           Variant="Variant.Outlined"
                           Class="settings-select">
                    <MudSelectItem Value="@("date")">Modified date</MudSelectItem>
                    <MudSelectItem Value="@("title")">Title</MudSelectItem>
                </MudSelect>
            </div>

            <div class="settings-row">
                <label class="settings-label">Default sort direction</label>
                <MudSelect T="string"
                           Value="_settings.DefaultSortDir"
                           ValueChanged="v => _settings.DefaultSortDir = v"
                           Dense="true"
                           Variant="Variant.Outlined"
                           Class="settings-select">
                    <MudSelectItem Value="@("desc")">Descending</MudSelectItem>
                    <MudSelectItem Value="@("asc")">Ascending</MudSelectItem>
                </MudSelect>
            </div>

            <div class="settings-row">
                <label class="settings-label">Notes per page</label>
                <MudSelect T="int"
                           Value="_settings.DefaultPageSize"
                           ValueChanged="v => _settings.DefaultPageSize = v"
                           Dense="true"
                           Variant="Variant.Outlined"
                           Class="settings-select">
                    <MudSelectItem Value="10">10</MudSelectItem>
                    <MudSelectItem Value="20">20</MudSelectItem>
                    <MudSelectItem Value="30">30</MudSelectItem>
                    <MudSelectItem Value="50">50</MudSelectItem>
                </MudSelect>
            </div>
        </div>

        <div class="settings-actions">
            <MudButton Variant="Variant.Filled"
                       Color="Color.Primary"
                       OnClick="SaveAsync"
                       Disabled="_isSaving">
                @(_isSaving ? "Saving..." : "Save")
            </MudButton>
        </div>

        <div class="settings-section">
            <h2 class="settings-section-title">API Tokens</h2>
            <p class="settings-hint">
                Personal access tokens let external scripts and services call the API
                without logging in. Send the token in the
                <code>Authorization: Bearer &lt;token&gt;</code> header. A token is shown
                only once at creation — store it somewhere safe.
            </p>

            @if (_newToken is not null)
            {
                <MudAlert Severity="Severity.Success" Class="mb-4" NoIcon="true">
                    <div class="token-reveal">
                        <div class="token-reveal-label">
                            New token "<strong>@_newToken.Name</strong>" — copy it now, it won't be shown again.
                        </div>
                        <div class="token-reveal-row">
                            <MudTextField T="string"
                                          Value="_newToken.Token"
                                          ReadOnly="true"
                                          Variant="Variant.Outlined"
                                          Margin="Margin.Dense"
                                          Class="token-reveal-value" />
                            <MudIconButton Icon="@Icons.Material.Filled.ContentCopy"
                                           Color="Color.Primary"
                                           OnClick="() => CopyToken(_newToken.Token)"
                                           title="Copy" />
                        </div>
                    </div>
                </MudAlert>
            }

            <div class="settings-actions" style="justify-content: flex-start; margin-bottom: 1rem;">
                <MudButton Variant="Variant.Filled"
                           Color="Color.Primary"
                           StartIcon="@Icons.Material.Filled.Add"
                           OnClick="OpenCreateDialog">
                    Create token
                </MudButton>
            </div>

            @if (_isLoadingTokens)
            {
                <p class="empty-message">Loading tokens...</p>
            }
            else if (_tokens.Count == 0)
            {
                <p class="empty-message">No API tokens yet.</p>
            }
            else
            {
                <MudTable Items="_tokens" Dense="true" Hover="true" Class="token-table">
                    <HeaderContent>
                        <MudTh>Name</MudTh>
                        <MudTh>Token</MudTh>
                        <MudTh>Created</MudTh>
                        <MudTh>Expires</MudTh>
                        <MudTh>Last used</MudTh>
                        <MudTh></MudTh>
                    </HeaderContent>
                    <RowTemplate>
                        <MudTd DataLabel="Name">@context.Name</MudTd>
                        <MudTd DataLabel="Token">van_pat_…@context.TokenSuffix</MudTd>
                        <MudTd DataLabel="Created">@context.CreatedAt.ToLocalTime().ToString("yyyy-MM-dd")</MudTd>
                        <MudTd DataLabel="Expires">@(context.ExpiresAt is null ? "Never" : context.ExpiresAt.Value.ToLocalTime().ToString("yyyy-MM-dd"))</MudTd>
                        <MudTd DataLabel="Last used">@(context.LastUsedAt is null ? "Never" : context.LastUsedAt.Value.ToLocalTime().ToString("yyyy-MM-dd HH:mm"))</MudTd>
                        <MudTd>
                            <MudIconButton Icon="@Icons.Material.Filled.Delete"
                                           Color="Color.Error"
                                           Size="Size.Small"
                                           OnClick="() => DeleteTokenAsync(context)"
                                           title="Revoke" />
                        </MudTd>
                    </RowTemplate>
                </MudTable>
            }
        </div>
    }
</div>

@code {
    private UserSettings _settings = new();
    private bool _isLoading = true;
    private bool _isSaving = false;

    private List<ApiTokenSummary> _tokens = new();
    private bool _isLoadingTokens = true;
    private CreateApiTokenResponse? _newToken;

    protected override async Task OnInitializedAsync()
    {
        var result = await SettingsService.GetAsync();
        if (result.IsSuccess)
            _settings = result.Value!;
        else
            Snackbar.Add(result.Error ?? "Failed to load settings.", Severity.Error);

        _isLoading = false;

        await LoadTokensAsync();
    }

    private async Task LoadTokensAsync()
    {
        _isLoadingTokens = true;
        var result = await ApiTokenService.ListAsync();
        if (result.IsSuccess)
            _tokens = result.Value!;
        else
            Snackbar.Add(result.Error ?? "Failed to load API tokens.", Severity.Error);
        _isLoadingTokens = false;
    }

    private async Task OpenCreateDialog()
    {
        var dialog = await DialogService.ShowAsync<CreateApiTokenDialog>("Create API token");
        var result = await dialog.Result;
        if (result is null || result.Canceled || result.Data is not CreateApiTokenRequest request)
            return;

        var created = await ApiTokenService.CreateAsync(request);
        if (created.IsSuccess)
        {
            _newToken = created.Value;
            Snackbar.Add("API token created.", Severity.Success);
            await LoadTokensAsync();
        }
        else
        {
            Snackbar.Add(created.Error ?? "Failed to create API token.", Severity.Error);
        }
    }

    private async Task DeleteTokenAsync(ApiTokenSummary token)
    {
        var parameters = new DialogParameters<ConfirmDialog>
        {
            { x => x.Message, $"Revoke \"{token.Name}\"? Any script using it will stop working immediately." },
            { x => x.ConfirmText, "Revoke" },
            { x => x.ConfirmColor, Color.Error }
        };
        var dialog = await DialogService.ShowAsync<ConfirmDialog>("Revoke token", parameters);
        var dialogResult = await dialog.Result;
        if (dialogResult is null || dialogResult.Canceled)
            return;

        var result = await ApiTokenService.DeleteAsync(token.Id);
        if (result.IsSuccess)
        {
            if (_newToken?.Id == token.Id)
                _newToken = null;
            Snackbar.Add("API token revoked.", Severity.Success);
            await LoadTokensAsync();
        }
        else
        {
            Snackbar.Add(result.Error ?? "Failed to revoke API token.", Severity.Error);
        }
    }

    private async Task CopyToken(string token)
    {
        await JS.InvokeVoidAsync("navigator.clipboard.writeText", token);
        Snackbar.Add("Token copied to clipboard.", Severity.Info);
    }

    private async Task SaveAsync()
    {
        _isSaving = true;
        var result = await SettingsService.SaveAsync(_settings);
        if (result.IsSuccess)
        {
            _settings = result.Value!;
            await JS.InvokeVoidAsync("storeTheme", _settings.Theme);
            await JS.InvokeVoidAsync("applyTheme", _settings.Theme);
            var isDark = _settings.Theme == "dark" ||
                         (_settings.Theme == "system" && await JS.InvokeAsync<bool>("getSystemDarkMode"));
            ThemeService.SetDarkMode(isDark);
            Snackbar.Add("Settings saved.", Severity.Success);
        }
        else
        {
            Snackbar.Add(result.Error ?? "Failed to save settings.", Severity.Error);
        }
        _isSaving = false;
    }
}
