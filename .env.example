# PostgreSQL connection settings
# Use host.docker.internal if running on the same machine, or the server IP otherwise
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=vanadium
DB_USER=postgres
DB_PASSWORD=your-db-password

AUTH_PASSWORD_HASH=your-bcrypt-hash
# Web app origin(s) for CORS (comma-separated if multiple)
CORS_ALLOWED_ORIGINS=http://localhost
AUTH_JWT_SECRET=your-jwt-secret-min-32-chars
API_BASE_URL=http://your-server-ip:5000
