# PostgreSQL connection settings
# Use host.docker.internal if running on the same machine, or the server IP otherwise
DB_HOST=host.docker.internal
DB_PORT=5432
DB_NAME=vanadium
DB_USER=postgres
DB_PASSWORD=your-db-password

AUTH_PASSWORD_HASH=your-bcrypt-hash
# Web app origin(s) for CORS (comma-separated if multiple)
CORS_ALLOWED_ORIGINS=http://localhost
AUTH_JWT_SECRET=your-jwt-secret-min-32-chars
API_BASE_URL=http://your-server-ip:5000

# Structured logging with Seq (optional)
# Leave SEQ_URL unset or empty to use console logging only.
#
# Setup:
#   1. Run a Seq instance:
#      docker run -d --name seq -e ACCEPT_EULA=Y -p 5341:80 datalust/seq
#   2. Open Seq UI (http://your-seq-server) → Settings → API Keys → Add API Key
#   3. Set the values below. Keep SEQ_URL port (5341) blocked from public access.
#
# SEQ_URL=http://your-seq-server:5341
# SEQ_API_KEY=your-seq-api-key
